rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    /**
     * SHIVA SHAKTHI JEWELLERS - UPDATED SECURITY RULES
     */

    function isSignedIn() {
      return request.auth != null;
    }

    /** 
     * ADMIN CHECK:
     * Authorizes master admin emails.
     */
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'raghuvarama66@gmail.com' || 
        request.auth.token.email == 'komaravellirakesh4@gmail.com' || 
        request.auth.token.email == 'makhilyadavmuddam@gmail.com' ||
        request.auth.token.email == 'shivashakthi9985@gmail.com' ||
        exists(/databases/$(database)/documents/roles_admin/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    match /roles_admin/{userId} {
      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create, update, delete: if isAdmin();
    }

    match /gold_prices/{goldPriceId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /tax_rate/{taxRateId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /admin_settings/{adminSettingsId} {
      allow get, list: if true;
      allow create, update, delete: if isAdmin();
    }

    match /users/KBS_SHARED_DATA {
      allow get: if isAdmin();
      match /calculations/{calculationId} {
        allow get, list, create, update, delete: if isAdmin();
      }
      match /notes/{noteId} {
        allow get, list, create, update, delete: if isAdmin();
      }
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId) || isAdmin();
      allow update, delete: if isAdmin();

      match /calculations/{calculationId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }

      match /notes/{noteId} {
        allow get, list: if isOwner(userId) || isAdmin();
        allow create, update, delete: if isOwner(userId) || isAdmin();
      }
    }
  }
}
